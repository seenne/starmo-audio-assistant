<Window x:Class="StarAudioAssistant.App.TaskEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="任务编辑向导"
        Width="760"
        Height="680"
        MinWidth="700"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#F7FAFF">
    <Border Margin="14" CornerRadius="12" BorderBrush="#D7E0EC" BorderThickness="1" Background="White" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#EEF5FF" CornerRadius="8" Padding="10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="步骤 1" FontSize="12" Foreground="#5A6F8F"/>
                        <TextBlock Text="基础信息" FontSize="14" FontWeight="SemiBold" Foreground="#1D3F6E"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#EEF5FF" CornerRadius="8" Padding="10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="步骤 2" FontSize="12" Foreground="#5A6F8F"/>
                        <TextBlock Text="时间与策略" FontSize="14" FontWeight="SemiBold" Foreground="#1D3F6E"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#EEF5FF" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="步骤 3" FontSize="12" Foreground="#5A6F8F"/>
                        <TextBlock Text="播放与校验" FontSize="14" FontWeight="SemiBold" Foreground="#1D3F6E"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TabControl Grid.Row="1"
                        x:Name="StepTabControl"
                        Margin="0,14,0,0"
                        BorderThickness="0"
                        Background="Transparent"
                        SelectionChanged="StepTabControl_SelectionChanged">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.Resources>

                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="任务名称" Foreground="#304A6D"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" x:Name="NameTextBox" Margin="0,0,0,10" Height="32" TextChanged="AnyFieldChanged"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="音频文件" Foreground="#304A6D"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="AudioPathTextBox" Margin="0,0,8,10" Height="32" TextChanged="AnyFieldChanged"/>
                            <Button Grid.Row="1" Grid.Column="2" x:Name="BrowseAudioButton" Content="浏览..." Padding="14,5" Click="BrowseButton_Click"/>

                            <CheckBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                      x:Name="EnabledCheckBox"
                                      Content="启用此任务"
                                      IsChecked="True"
                                      Foreground="#304A6D"
                                      Margin="0,2,0,0"
                                      Checked="AnyFieldChanged"
                                      Unchecked="AnyFieldChanged"/>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="108"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="执行类型" Foreground="#304A6D"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" x:Name="RecurrenceModeComboBox" Width="180" Height="32" SelectionChanged="RecurrenceModeComboBox_SelectionChanged">
                                <ComboBoxItem Content="每周循环" Tag="Weekly" IsSelected="True"/>
                                <ComboBoxItem Content="单次执行" Tag="OneTime"/>
                            </ComboBox>

                            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" x:Name="WeeklyPanel" Margin="0,10,0,0" BorderBrush="#D7E0EC" BorderThickness="1" CornerRadius="8" Padding="10" Background="#FBFDFF">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="开始" Foreground="#304A6D"/>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                                        <ComboBox x:Name="StartDayComboBox" Width="180" Margin="0,0,8,0" SelectionChanged="AnyFieldChanged"/>
                                        <TextBox x:Name="StartTimeTextBox" Width="120" TextChanged="AnyFieldChanged"/>
                                        <TextBlock Text="HH:mm" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#6A7F9F"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="结束" Foreground="#304A6D"/>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                                        <ComboBox x:Name="EndDayComboBox" Width="180" Margin="0,0,8,0" SelectionChanged="AnyFieldChanged"/>
                                        <TextBox x:Name="EndTimeTextBox" Width="120" TextChanged="AnyFieldChanged"/>
                                        <TextBlock Text="HH:mm" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#6A7F9F"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="排程模式" Foreground="#304A6D"/>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                        <ComboBox x:Name="ScheduleModeComboBox" Width="180" SelectionChanged="AnyFieldChanged">
                                            <ComboBoxItem Content="每周" Tag="EveryWeek" IsSelected="True"/>
                                            <ComboBoxItem Content="仅工作日" Tag="WeekdaysOnly"/>
                                        </ComboBox>
                                        <CheckBox x:Name="SkipHolidayCheckBox"
                                                  Content="节假日跳过"
                                                  Margin="16,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Checked="AnyFieldChanged"
                                                  Unchecked="AnyFieldChanged"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" x:Name="OneTimePanel" Margin="0,10,0,0" BorderBrush="#D7E0EC" BorderThickness="1" CornerRadius="8" Padding="10" Background="#FBFDFF" Visibility="Collapsed">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="开始" Foreground="#304A6D"/>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                                        <DatePicker x:Name="OneTimeStartDatePicker" Width="150" SelectedDateChanged="AnyFieldChanged"/>
                                        <TextBox x:Name="OneTimeStartTimeTextBox" Width="120" Margin="8,0,0,0" TextChanged="AnyFieldChanged"/>
                                        <TextBlock Text="HH:mm" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#6A7F9F"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="结束" Foreground="#304A6D"/>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                        <DatePicker x:Name="OneTimeEndDatePicker" Width="150" SelectedDateChanged="AnyFieldChanged"/>
                                        <TextBox x:Name="OneTimeEndTimeTextBox" Width="120" Margin="8,0,0,0" TextChanged="AnyFieldChanged"/>
                                        <TextBlock Text="HH:mm" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#6A7F9F"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="临时停用" Foreground="#304A6D" Margin="0,12,0,0"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,12,0,0">
                                <CheckBox x:Name="PauseTaskCheckBox" Content="停用至" VerticalAlignment="Center" Checked="PauseTaskCheckBox_Changed" Unchecked="PauseTaskCheckBox_Changed"/>
                                <DatePicker x:Name="PauseUntilDatePicker" Width="150" Margin="8,0,0,0" IsEnabled="False" SelectedDateChanged="AnyFieldChanged"/>
                            </StackPanel>

                            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="优先级" Foreground="#304A6D" Margin="0,12,0,0"/>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="PriorityTextBox" Width="120" Height="32" Margin="0,12,0,0" TextChanged="AnyFieldChanged"/>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="淡入/淡出" Foreground="#304A6D"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBox x:Name="FadeInTextBox" Width="120" TextChanged="AnyFieldChanged"/>
                                <TextBlock Text="/" Margin="8,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="FadeOutTextBox" Width="120" TextChanged="AnyFieldChanged"/>
                                <TextBlock Text="毫秒" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="#6A7F9F"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Top" Text="冲突检测" Foreground="#304A6D"/>
                            <Border Grid.Row="1" Grid.Column="1" Background="#FFF6EC" BorderBrush="#FFD8AE" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock x:Name="ConflictSummaryText" Foreground="#8B4A05" Text="暂无冲突" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="ConflictAdviceText" Margin="0,6,0,0" Foreground="#8B4A05" TextWrapping="Wrap"/>
                                    <Button x:Name="ApplyPrioritySuggestionButton"
                                            Content="应用建议优先级"
                                            Padding="12,5"
                                            Margin="0,8,0,0"
                                            HorizontalAlignment="Left"
                                            Visibility="Collapsed"
                                            Click="ApplyPrioritySuggestionButton_Click"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Top" Text="健康检查" Foreground="#304A6D"/>
                            <Border Grid.Row="2" Grid.Column="1" BorderBrush="#D7E0EC" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10" Background="#F9FCFF">
                                <TextBlock x:Name="HealthCheckText" Foreground="#284468" Text="待检测" TextWrapping="Wrap"/>
                            </Border>

                            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Top" Text="未来触发" Foreground="#304A6D"/>
                            <ListBox Grid.Row="3" Grid.Column="1" x:Name="PreviewListBox" Height="140" BorderBrush="#D7E0EC" BorderThickness="1" Background="#FBFDFF"/>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <TextBlock Grid.Row="2"
                       x:Name="ValidationTextBlock"
                       Foreground="#B42318"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap"/>

            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" x:Name="BackButton" Content="上一步" Padding="14,6" Margin="0,0,8,0" Click="BackButton_Click"/>
                <Button Grid.Column="2" x:Name="NextButton" Content="下一步" Padding="14,6" Margin="0,0,8,0" Click="NextButton_Click"/>
                <Button Grid.Column="3" x:Name="CancelButton" Content="取消" Padding="14,6" Margin="0,0,8,0" IsCancel="True"/>
                <Button Grid.Column="4" x:Name="SaveButton" Content="保存" Padding="16,6" IsDefault="True" Click="SaveButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>

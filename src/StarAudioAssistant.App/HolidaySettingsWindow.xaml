<Window x:Class="StarAudioAssistant.App.HolidaySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="节假日设置"
        Width="460"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F7FAFF">
    <Border Margin="14" CornerRadius="10" BorderBrush="#D7E0EC" BorderThickness="1" Background="White" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="节假日日期（用于“节假日跳过”策略）"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Foreground="#1B3761"
                       Margin="0,0,0,12"/>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <DatePicker x:Name="HolidayDatePicker" SelectedDateFormat="Short"/>
                <Button Grid.Column="1" x:Name="AddHolidayButton" Content="添加" Padding="14,5" Margin="8,0,0,0" Click="AddButton_Click"/>
                <Button Grid.Column="2" x:Name="RemoveHolidayButton" Content="移除选中" Padding="14,5" Margin="8,0,0,0" IsEnabled="False" Click="RemoveButton_Click"/>
            </Grid>

            <ListBox Grid.Row="2"
                     x:Name="DateListBox"
                     SelectionChanged="DateListBox_SelectionChanged"
                     BorderBrush="#D7E0EC"
                     BorderThickness="1"
                     Background="#FBFDFF"/>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button x:Name="CancelHolidayButton" Content="取消" Padding="16,6" Margin="0,0,8,0" IsCancel="True"/>
                <Button x:Name="SaveHolidayButton" Content="保存" Padding="16,6" IsDefault="True" Click="SaveButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

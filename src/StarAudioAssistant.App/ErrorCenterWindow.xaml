<Window x:Class="StarAudioAssistant.App.ErrorCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="错误中心"
        Width="840"
        Height="520"
        WindowStartupLocation="CenterOwner"
        Background="#F6FAFF">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="最近错误与诊断信息" FontSize="20" FontWeight="SemiBold" Foreground="#16345F" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1"
                  x:Name="ErrorGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  AlternatingRowBackground="#FAFCFF"
                  BorderBrush="#D7E0EC"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="时间" Binding="{Binding When, StringFormat={}{0:MM-dd HH:mm:ss}}" Width="130"/>
                <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="140"/>
                <DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="220"/>
                <DataGridTextColumn Header="详情" Binding="{Binding Details}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CopyButton" Content="复制诊断文本" Padding="14,6" Margin="0,0,8,0" Click="CopyButton_Click"/>
            <Button x:Name="CloseErrorCenterButton" Content="关闭" Padding="14,6" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
